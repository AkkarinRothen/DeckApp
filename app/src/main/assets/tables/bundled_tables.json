      "rollFormula": "1d10",
      "rollMode": "RANGE",
      "entries": [
        { "minRoll": 1,  "maxRoll": 2,  "text": "Resbalón. Caes prono. Levantarse cuesta movimiento." },
        { "minRoll": 3,  "maxRoll": 4,  "text": "Golpeas a un aliado adyacente. Daño normal." },
        { "minRoll": 5,  "maxRoll": 6,  "text": "El arma se atasca. Acción para librarla." },
        { "minRoll": 7,  "maxRoll": 8,  "text": "Sobre-extensión. Desventaja en el siguiente ataque." },
        { "minRoll": 9,  "maxRoll": 9,  "text": "El arma se rompe. Pierde [1d4] puntos de daño permanentemente." },
        { "minRoll": 10, "maxRoll": 10, "text": "Crítico fallido total. Pierdes tu turno y quedas aturdido." }
