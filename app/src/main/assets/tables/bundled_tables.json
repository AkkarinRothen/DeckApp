    {
      "name": "Resultado de Crítico",
      "description": "Efectos adicionales en un golpe crítico.",
      "category": "Combate",
      "rollFormula": "1d10",
      "rollMode": "RANGE",
      "entries": [
        { "minRoll": 1,  "maxRoll": 2,  "text": "Daño doble. El enemigo sangra ([1d4] daño al inicio de su turno)." },
        { "minRoll": 3,  "maxRoll": 4,  "text": "Golpe ensordecedor. El enemigo tiene desventaja en percepción 1 turno." },
        { "minRoll": 5,  "maxRoll": 6,  "text": "Arma volando. El enemigo pierde su arma a [1d4] metros." },
        { "minRoll": 7,  "maxRoll": 8,  "text": "Rodilla rota. Velocidad del enemigo reducida a la mitad 2 turnos." },
        { "minRoll": 9,  "maxRoll": 9,  "text": "Golpe en la cabeza. El enemigo queda aturdido hasta su próximo turno." },
        { "minRoll": 10, "maxRoll": 10, "text": "Herida espectacular. +[1d6] daño adicional. El enemigo pierde moral." }
      ]
    },
    {
      "name": "Resultado de Pifia",
      "description": "Efectos al sacar un 1 natural en un ataque.",
